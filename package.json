{
  "name": "ssh-ai-shell",
  "version": "1.0.0",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"yellow.bold,cyan.bold\" \"nodemon server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "start:desktop": "npm run build && electron .",
    "build:desktop": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win nsis portable",
    "build:mac": "npm run build && electron-builder --mac dmg zip"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "ansi-to-html": "^0.7.2",
    "busboy": "^1.6.0",
    "express": "^4.18.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "ssh2": "^1.16.0",
    "strip-ansi": "^7.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "build": {
    "appId": "com.sshaishell.desktop",
    "productName": "SSH AI Shell",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
